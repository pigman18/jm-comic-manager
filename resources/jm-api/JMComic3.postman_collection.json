      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const ts = Math.floor(Date.now() / 1000);",
          "const version = '1.6.3';",
          "const secret = '18comicAPP';",
          "const token = CryptoJS.MD5(ts + secret).toString();",
          "pm.request.headers.upsert({ key: 'ts', value: String(ts) });",
          "pm.request.headers.upsert({ key: 'token', value: token });",
          "pm.request.headers.upsert({ key: 'tokenparam', value: `${ts},${version}` });",
          "// Inject auth headers from collection variables (set by login)",
          "const jwt = pm.collectionVariables.get('jwttoken');",
          "if (jwt) { pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + jwt }); }",
          "const avs = pm.collectionVariables.get('memberS');",
          "if (avs) { pm.request.headers.upsert({ key: 'Cookie', value: 'AVS=' + avs }); }",
          "pm.variables.set('ts', ts);",
          "pm.variables.set('token', token);"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "test",
      "script": {
        "exec": [
          "const ts = pm.variables.get('ts');",
          "const text = pm.response.text();",
          "",
          "// ── CDN 主机发现 ──────────────────────────",
          "const url = pm.request.url.toString();",
          "if (url.includes('bytepluses.com')) {",
          "  const cdnKey = CryptoJS.enc.Utf8.parse(CryptoJS.MD5('diosfjckwpqpdfjkvnqQjsik').toString());",
          "  try {",
          "    const decrypted = CryptoJS.AES.decrypt(text, cdnKey, { mode: CryptoJS.mode.ECB, padding: CryptoJS.pad.Pkcs7 }).toString(CryptoJS.enc.Utf8);",
          "    const config = JSON.parse(decrypted);",
          "    console.log('Host config:', config);",
          "    if (config.Server && config.Server.length > 0) {",
          "      pm.collectionVariables.set('apiUrl', 'https://' + config.Server[0] + '/');",
          "      console.log('apiUrl set to:', 'https://' + config.Server[0] + '/');",
          "    }",
          "    setDataView(config);",
          "  } catch(e) { console.log('CDN decryption failed:', e); }",
          "  return;",
          "}",
          "",
          "// ── API 响应解密 ──────────────────────────",
          "let data = (text.includes('code') && text.includes('data')) ? JSON.parse(text).data : text;",
          "let result = null;",
          "const secrets = ['185Hcomic3PAPP7R', '18comicAPPContent'];",
          "const urlIncludesAd = url.includes('ad_content_all') || url.includes('advertise_all');",
          "for (const secret of secrets) {",
          "  const combos = urlIncludesAd ? [secret] : [ts + secret];",
          "  for (const keyInput of combos) {",
          "    try {",
          "      const aesKey = CryptoJS.enc.Utf8.parse(CryptoJS.MD5(keyInput).toString());",
          "      result = JSON.parse(CryptoJS.AES.decrypt(data, aesKey, { mode: CryptoJS.mode.ECB, padding: CryptoJS.pad.Pkcs7 }).toString(CryptoJS.enc.Utf8));",
          "      break;",
          "    } catch(e) { /* try next */ }",
          "  }",
          "  if (result) break;",
          "}",
          "if (!result) { console.log('Decryption failed with all keys', {url, data}); return; }",
"console.log('Decrypted:', JSON.stringify(result).slice(0, 200));",
"if (result.jwttoken) {",
"  pm.collectionVariables.set('jwttoken', result.jwttoken);",
"  console.log('✅ jwttoken saved to collection variables');",
"}",
"if (result.memberInfo && result.memberInfo.s) {",
"  pm.collectionVariables.set('memberS', result.memberInfo.s);",
"  console.log('✅ memberInfo.s saved to collection variables');",
"}",
          "setDataView(result);",
          "",
          "/**",
          " * 渲染到 Visualize 标签",
          " */",
          "function setDataView(data) {",
          "  pm.visualizer.set(`",
          "<!DOCTYPE html>",
          "<html>",
          "<head>",
          "  <meta charset=\"utf-8\" />",
          "  <link",
          "    href=\"https://cdn.jsdelivr.net/npm/jsoneditor@9/dist/jsoneditor.min.css\"",
          "    rel=\"stylesheet\"",
          "  />",
          "  <style>",
          "    html, body {",
          "      width: 100%;",
          "      height: 100%;",
          "      margin: 0;",
          "      padding: 0;",
          "      background: #1e1e1e;",
          "    }",
          "    #editor {",
          "      width: 100%;",
          "      height: 100%;",
          "    }",
          "  </style>",
          "</head>",
          "<body>",
          "  <div id=\"editor\"></div>",
          "  <script src=\"https://cdn.jsdelivr.net/npm/jsoneditor@9/dist/jsoneditor.min.js\"></script>",
          "  <script>",
          "    const container = document.getElementById('editor');",
          "    const options = {",
          "      mode: 'tree',",
          "      mainMenuBar: true,",
          "      navigationBar: true,",
          "      statusBar: false,",
          "      theme: 'ace/theme/monokai'",
          "    };",
          "    const editor = new JSONEditor(container, options);",
          "    editor.set(${JSON.stringify(data)});",
          "  </script>",
          "</body>",
          "</html>",
          "`);",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
